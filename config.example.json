{
    "run": {
        "count": 10
    },
    "register_mode": "browser",
    "pool": {
        "count": 10,
        "concurrent": 2,
        "stagger_sec": 20,
        "display": "headless",
        "proxy_mode": "per_account",
        "proxy_file": "proxy.txt",
        "proxies": [],
        "proxy_check": true,
        "proxy_check_url": "https://accounts.x.ai/",
        "proxy_max_ms": 4000,
        "proxy_check_timeout": 12,
        "proxy_check_workers": 10,
        "proxy_retries": 3,
        "proxy_fallback_direct": true,
        "block_assets": true
    },
    "email": {
        "provider": "imap",
        "domain": "yourdomain.com",
        "local_style": "human",
        "imap_user": "you@gmail.com",
        "imap_pass": "abcd efgh ijkl mnop",
        "imap_host": "imap.gmail.com",
        "imap_port": 993,
        "exzork_api_key": "",
        "exzork_base_url": "https://mailer.exzork.me",
        "exzork_use_subdomain": true,
        "_comment_provider": "imap = Gmail catch-all | exzork = mailer.exzork.me (wildcard MX). Prefer env EXZORK_API_KEY over config key."
    },
    "proxy": "",
    "browser_proxy": "",
    "browser": {
        "engine": "camoufox"
    },
    "account": {
        "password": "Nfarm!a7#GrokBuild26",
        "_comment_password": "Fixed password for ALL farmed accounts (not random). Override with env GROK_ACCOUNT_PASSWORD. Saved to accounts/email_pass.txt + accounts/accounts.jsonl"
    },
    "grok_cli": {
        "enabled": true,
        "base_url": "https://ai.khalid.id",
        "password": "your-9router-dashboard-password",
        "data_dir": "~/.9router",
        "cli_token": "",
        "oauth_mode": "auto",
        "oauth_referrer": "grok-build",
        "_comment_oauth_mode": "auto = PKCE on Camoufox, device SSO on Chromium (no :56121 lock). pkce | device | auto. Force Chromium PKCE: GROK_FORCE_CHROMIUM_PKCE=1",
        "post_signup_settle_sec": 12,
        "oauth_gap_sec": 8,
        "chat_probe_off_critical": true,
        "inject_policy": "usable",
        "jwt_reject_bot_flag": false,
        "jwt_enforce_referrer": true,
        "chat_probe_model": "grok-4.5",
        "smoke_bot_flag": true,
        "smoke_model": "grok-4.5",
        "smoke_timeout_sec": 45
    },
    "grok2api": {
        "enabled": false,
        "base_url": "http://127.0.0.1:8000",
        "username": "admin",
        "password": "your-admin-password",
        "tier": "auto"
    },
    "ninerouter": {
        "enabled": false,
        "base_url": "http://127.0.0.1:20127",
        "provider": "grok-web",
        "data_dir": "~/.9router"
    }
}
